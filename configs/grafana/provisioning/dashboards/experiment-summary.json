          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  s.id::text as session_id,\n  v.name as variant,\n  s.status,\n  s.outcome_state,\n  COUNT(r.id) as request_count,\n  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY r.latency_ms) as p50_latency,\n  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY r.ttft_ms) as p50_ttft,\n  EXTRACT(EPOCH FROM (s.ended_at - s.started_at))/60.0 as duration,\n  s.started_at\nFROM sessions s\nJOIN variants v ON s.variant_id = v.id\nLEFT JOIN requests r ON r.session_id = s.id\nWHERE s.experiment_id = (SELECT id FROM experiments WHERE name = '$experiment' LIMIT 1)\nGROUP BY s.id, v.name, s.status, s.outcome_state, s.started_at, s.ended_at\nORDER BY s.started_at DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
