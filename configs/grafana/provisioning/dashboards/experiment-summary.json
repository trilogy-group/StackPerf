      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-datasource"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  v.name as variant,\n  v.provider,\n  v.model_alias,\n  COUNT(DISTINCT s.id) as session_count,\n  COUNT(r.id) as request_count,\n  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY r.latency_ms) as p50_latency,\n  PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY r.latency_ms) as p95_latency,\n  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY r.ttft_ms) as p50_ttft,\n  COALESCE(100.0 * SUM(CASE WHEN r.error THEN 1 ELSE 0 END) / NULLIF(COUNT(r.id), 0), 0) as error_rate,\n  SUM(COALESCE(r.tokens_prompt, 0) + COALESCE(r.tokens_completion, 0)) as total_tokens\nFROM variants v\nLEFT JOIN sessions s ON s.variant_id = v.id AND s.experiment_id = (SELECT id FROM experiments WHERE name = '$experiment' LIMIT 1)\nLEFT JOIN requests r ON r.session_id = s.id\nWHERE v.id IN (\n  SELECT variant_id FROM experiment_variants WHERE experiment_id = (SELECT id FROM experiments WHERE name = '$experiment' LIMIT 1)\n)\nGROUP BY v.id, v.name, v.provider, v.model_alias\nORDER BY p50_latency",
          "refId": "A"
        }
      ],
      "title": "Variant Comparison Summary",
      "type": "table"
