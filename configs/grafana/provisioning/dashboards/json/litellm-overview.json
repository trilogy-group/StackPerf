{
  "dashboard": {
    "title": "LiteLLM Overview",
    "uid": "litellm-overview",
    "tags": ["litellm", "stackperf"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(litellm_requests_total[5m])",
            "refId": "A",
            "legendFormat": "{{model}}"
          }
        ]
      },
      {
        "title": "Request Latency (p50, p95, p99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(litellm_request_duration_seconds_bucket[5m]))",
            "refId": "A",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(litellm_request_duration_seconds_bucket[5m]))",
            "refId": "B",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(litellm_request_duration_seconds_bucket[5m]))",
            "refId": "C",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(litellm_requests_failed_total[5m]) / rate(litellm_requests_total[5m])",
            "refId": "A",
            "legendFormat": "error rate"
          }
        ]
      },
      {
        "title": "Tokens Processed",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(litellm_total_tokens_total[5m])",
            "refId": "A",
            "legendFormat": "total tokens/s"
          }
        ]
      }
    ]
  }
}
