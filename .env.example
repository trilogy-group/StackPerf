# FIREWORKS_API_KEY=...
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=sk-ant-...
